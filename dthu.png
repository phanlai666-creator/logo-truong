    <script type="text/javascript">
        $(document).ready(function () {
            $("#logo-metal").click(function () {
                $("#links").slideDown(1000);
                $("#logo-metal").hide();
                $("#close").show();
            });

            $("#close").click(function () {
                $("#close").hide();
                $("#links").slideUp(1000);
                $("#logo-metal").show();
            });
        });
    </script>

